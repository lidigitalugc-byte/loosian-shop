# =============================================
# LOOSIAN GROCERS - M-PESA DARAJA API CONFIG
# =============================================
# Get these from https://developer.safaricom.co.ke

# --- SAFARICOM DARAJA CREDENTIALS ---
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# --- BUSINESS SHORTCODE ---
# For Paybill: your Paybill number
# For Till: your Till number (Buy Goods)
MPESA_SHORTCODE=174379

# --- LIPA NA MPESA PASSKEY ---
# Get this from Daraja portal under your app's LNM passkey
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# --- CALLBACK URL ---
# Public HTTPS URL where Safaricom will send payment confirmation
# Use ngrok for local testing: https://yoursubdomain.ngrok.io
CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# --- ENVIRONMENT ---
# sandbox  = testing (use Safaricom sandbox credentials)
# live     = production (use real Safaricom credentials)
MPESA_ENV=sandbox

# --- SERVER ---
PORT=3000

# --- DATABASE ---
# Railway adds this automatically when you add a PostgreSQL plugin
# It looks like: postgresql://user:pass@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/railway

# --- ADMIN PANEL ---
# Choose any strong password — used to view orders at /api/orders
# Header: Authorization: Bearer YOUR_SECRET_HERE
ADMIN_SECRET=choose-a-strong-secret-here

# --- BUSINESS INFO ---
BUSINESS_NAME=Loosian Grocers
BUSINESS_PHONE=0723851228
